{
  "name": "conference-hall",
  "version": "1.0.0",
  "private": true,
  "license": "AGPL-3.0",
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "dev": "pnpm --reporter=append-only run /^dev:/",
    "dev:web": "tsx ./servers/web.dev.ts",
    "dev:job": "tsx watch ./servers/jobs.ts",
    "start": "node ./build/server/index.js",
    "build": "prisma generate && react-router build",
    "jobs:start": "tsx ./servers/jobs.ts",
    "jobs:build": "prisma generate",
    "test": "pnpm test:db && pnpm test:unit",
    "test:db": "NODE_ENV=test prisma db push --accept-data-loss",
    "test:unit": "vitest --browser.headless",
    "test:ui": "vitest --project browser",
    "test:e2e": "NODE_ENV=test playwright test",
    "test:e2e:ui": "NODE_ENV=test playwright test --ui --ui-host=localhost",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:reset": "prisma migrate reset -f && prisma generate && prisma db seed",
    "lint": "oxlint",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "tsc": "react-router typegen && tsc -b",
    "knip": "knip"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1070.0",
    "@conform-to/zod": "^1.19.4",
    "@date-fns/tz": "^1.5.0",
    "@dnd-kit/abstract": "^0.5.0",
    "@dnd-kit/dom": "^0.5.0",
    "@dnd-kit/geometry": "^0.5.0",
    "@dnd-kit/react": "^0.5.0",
    "@floating-ui/react": "^0.27.19",
    "@headlessui/react": "^2.2.10",
    "@heroicons/react": "^2.2.0",
    "@marsidev/react-turnstile": "^1.5.3",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@react-router/express": "~7.16.0",
    "@react-router/node": "~7.16.0",
    "@remix-run/form-data-parser": "^0.17.3",
    "@sindresorhus/slugify": "^3.0.0",
    "@tanstack/react-hotkeys": "^0.10.0",
    "better-auth": "^1.6.19",
    "bullmq": "^5.78.1",
    "class-variance-authority": "^0.7.1",
    "compression": "^1.8.1",
    "date-fns": "^4.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "firebase-scrypt": "^2.2.0",
    "helmet": "^8.2.0",
    "i18next": "^26.3.1",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-fetch-backend": "^7.0.0",
    "ioredis": "^5.10.1",
    "isbot": "^5.1.43",
    "json-2-csv": "^5.5.11",
    "mailgun.js": "^13.2.0",
    "marked": "^18.0.5",
    "nodemailer": "^8.0.11",
    "picocolors": "^1.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-email": "^6.6.3",
    "react-i18next": "^17.0.8",
    "react-router": "~7.16.0",
    "recharts": "^3.8.1",
    "remix-i18next": "^7.5.0",
    "sitemap": "^9.0.1",
    "sonner": "^2.0.7",
    "use-debounce": "^10.1.1",
    "xss": "^1.0.15",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@mdx-js/rollup": "^3.1.1",
    "@ngneat/falso": "^8.0.2",
    "@playwright/test": "^1.61.0",
    "@react-router/dev": "~7.16.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.1",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/mdx": "^2.0.14",
    "@types/node": "^24.13.2",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/browser-playwright": "^4.1.9",
    "knip": "^6.17.1",
    "lefthook": "^2.1.9",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "vitest-browser-react": "^2.2.0"
  },
  "packageManager": "pnpm@11.7.0"
}
