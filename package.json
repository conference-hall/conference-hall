{
  "name": "conference-hall",
  "version": "1.0.0",
  "private": true,
  "license": "AGPL-3.0",
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "dev": "concurrently -k -c 'yellow,blue' 'npm:dev:*'",
    "dev:web": "tsx ./servers/web.dev.ts",
    "dev:job": "tsx watch ./servers/jobs.ts",
    "start": "node ./build/server/index.js",
    "build": "prisma generate && react-router build",
    "jobs:start": "tsx ./servers/jobs.ts",
    "jobs:build": "prisma generate",
    "test": "npm run test:db && npm run test:unit",
    "test:db": "NODE_ENV=test prisma db push --accept-data-loss",
    "test:unit": "vitest --browser.headless",
    "test:ui": "vitest --project browser",
    "test:e2e": "NODE_ENV=test playwright test",
    "test:e2e:ui": "NODE_ENV=test playwright test --ui --ui-host=localhost",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:reset": "prisma migrate reset -f && prisma generate && prisma db seed",
    "lint": "oxlint",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "tsc": "react-router typegen && tsc -b",
    "knip": "knip"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1031.0",
    "@conform-to/zod": "^1.19.0",
    "@dnd-kit/abstract": "^0.3.2",
    "@dnd-kit/dom": "^0.3.2",
    "@dnd-kit/geometry": "^0.3.2",
    "@dnd-kit/react": "^0.3.2",
    "@floating-ui/react": "^0.27.19",
    "@headlessui/react": "^2.2.10",
    "@heroicons/react": "^2.2.0",
    "@marsidev/react-turnstile": "^1.5.0",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@react-email/components": "^1.0.12",
    "@react-router/express": "~7.14.1",
    "@react-router/node": "~7.14.1",
    "@remix-run/form-data-parser": "^0.16.0",
    "@sindresorhus/slugify": "^3.0.0",
    "better-auth": "^1.6.5",
    "bullmq": "^5.74.1",
    "class-variance-authority": "^0.7.1",
    "compression": "^1.8.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "firebase-scrypt": "^2.2.0",
    "helmet": "^8.1.0",
    "i18next": "^26.0.5",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-fetch-backend": "^7.0.0",
    "ioredis": "^5.10.1",
    "isbot": "^5.1.39",
    "json-2-csv": "^5.5.10",
    "mailgun.js": "^12.9.0",
    "marked": "^18.0.1",
    "nodemailer": "^8.0.5",
    "picocolors": "^1.1.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^17.0.4",
    "react-router": "~7.14.1",
    "recharts": "^3.8.1",
    "remix-i18next": "^7.5.0",
    "sitemap": "^9.0.1",
    "sonner": "^2.0.7",
    "use-debounce": "^10.1.1",
    "uuid": "^13.0.0",
    "xss": "^1.0.15",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@mdx-js/rollup": "^3.1.1",
    "@ngneat/falso": "^8.0.2",
    "@playwright/test": "^1.59.1",
    "@react-router/dev": "~7.14.1",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@types/compression": "^1.8.1",
    "@types/mdx": "^2.0.13",
    "@types/node": "^24.12.2",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/browser-playwright": "^4.1.4",
    "concurrently": "^9.2.1",
    "knip": "^6.4.1",
    "lefthook": "^2.1.6",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "prisma": "^7.7.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.8",
    "vitest": "^4.1.4",
    "vitest-browser-react": "^2.2.0"
  }
}
